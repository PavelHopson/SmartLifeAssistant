# Database (SQLite — default for desktop, no setup needed)
DATABASE_URL="file:./smart-life.db"

# Desktop mode (auto-login without Google OAuth)
DESKTOP_MODE=true

# Auth
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — only for web version)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# TrueLayer (optional — bank connection)
TRUELAYER_CLIENT_ID=""
TRUELAYER_CLIENT_SECRET=""
TRUELAYER_REDIRECT_URI="http://localhost:3000/api/truelayer/callback"
TRUELAYER_SANDBOX=true

# Email (optional — Resend)
RESEND_API_KEY=""
EMAIL_FROM="Smart Life <noreply@smartlife.app>"

# AI (optional — Anthropic Claude)
ANTHROPIC_API_KEY=""

# Cron protection
CRON_SECRET=""

# Redis (optional — for multi-instance realtime)
REDIS_URL=""
REALTIME_PROVIDER=""

# Stripe (optional — monetization)
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""
